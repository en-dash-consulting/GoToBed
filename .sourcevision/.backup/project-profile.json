{
  "schemaVersion": "1.0.0",
  "primaryLanguage": "swift",
  "languages": [
    "swift",
    "markdown",
    "other",
    "shell",
    "yaml",
    "json",
    "text",
    "toml",
    "makefile",
    "html",
    "xml"
  ],
  "frameworks": [
    "appkit",
    "combine",
    "swiftpm",
    "swiftui"
  ],
  "releaseInfrastructure": [
    {
      "kind": "release-please",
      "evidence": ".release-please-manifest.json"
    },
    {
      "kind": "version-file",
      "evidence": "VERSION"
    }
  ],
  "buildSurfaces": [
    {
      "path": "Makefile",
      "kind": "Makefile"
    },
    {
      "path": "Package.swift",
      "kind": "swift package"
    }
  ],
  "ciSurfaces": [
    {
      "path": ".github/workflows/ci.yml",
      "kind": "GitHub Actions"
    },
    {
      "path": ".github/workflows/release.yml",
      "kind": "GitHub Actions"
    }
  ],
  "importGraphQuality": "rich"
}
